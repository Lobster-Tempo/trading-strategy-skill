{
  "name": "trading-strategy-skill",
  "version": "1.0.0",
  "description": "基于OKX CLI的多策略交易信号分析技能，集成RSI和MACD技术指标，提供智能买卖信号和风险管理建议",
  "main": "src/TradingStrategySkill.js",
  "bin": {
    "trading-strategy": "./scripts/analyze.js"
  },
  "scripts": {
    "start": "node scripts/analyze.js",
    "analyze": "node scripts/analyze.js",
    "batch": "node scripts/batch-analyze.js",
    "dev": "node scripts/analyze.js --symbol BTC/USDT --timeframe 1h",
    "test": "echo \"运行策略测试...\" && node -e \"const TradingStrategySkill = require('./src/TradingStrategySkill'); const skill = new TradingStrategySkill(); console.log('技能初始化成功:', skill.getInfo());\"",
    "test:unit": "echo \"单元测试...\"",
    "test:integration": "echo \"集成测试...\"",
    "test:coverage": "echo \"覆盖率测试...\"",
    "lint": "echo \"代码检查...\"",
    "lint:fix": "echo \"代码修复...\"",
    "format": "echo \"代码格式化...\"",
    "docs": "echo \"生成文档...\"",
    "okx:test": "echo \"模拟OKX CLI测试...\" && node scripts/okx-integration-test.js"
  },
  "keywords": [
    "okx",
    "trading",
    "strategy",
    "analysis",
    "crypto",
    "cli",
    "rsi",
    "macd",
    "technical-analysis",
    "signal",
    "risk-management"
  ],
  "author": "菊中菊 <yu230650@github.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "technicalindicators": "^3.1.0",
    "dotenv": "^16.3.0",
    "winston": "^3.11.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "standard": "^17.1.0",
    "prettier": "^3.1.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lobster-Tempo/trading-strategy-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Lobster-Tempo/trading-strategy-skill/issues"
  },
  "homepage": "https://github.com/Lobster-Tempo/trading-strategy-skill#readme",
  "files": [
    "src/",
    "scripts/",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "okxSkill": {
    "name": "trading-strategy",
    "title": "智能交易信号",
    "description": "基于OKX CLI的多策略交易信号分析技能",
    "version": "1.0.0",
    "category": "trading-analysis",
    "tags": ["trading", "strategy", "analysis", "crypto"],
    "requires": ["okx-cli"],
    "commands": ["analyze", "batch", "history", "backtest"]
  }
}