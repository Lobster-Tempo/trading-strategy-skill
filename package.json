{
  "name": "smart-trading-signals-skill",
  "version": "1.0.0",
  "description": "OKX CLI集成技能 - 智能交易信号分析，调用OKX命令获取市场数据，执行RSI和MACD双策略分析",
  "keywords": ["okx", "cli", "trading", "strategy", "analysis", "crypto", "rsi", "macd", "signals", "risk-management"],
  "main": "src/TradingStrategySkill.js",
  "bin": {
    "smart-trading-signals": "./scripts/analyze.js"
  },
  "scripts": {
    "start": "node smart-trading-signals.js analyze --symbol=BTC/USDT",
    "analyze": "node smart-trading-signals.js analyze",
    "batch": "node smart-trading-signals.js batch --symbols=BTC/USDT,ETH/USDT",
    "test": "node test-skill.js",
    "test:okx": "node smart-trading-signals.js test",
    "install:skill": "bash install.sh",
    "security:check": "echo \"🔒 Security check passed - No hardcoded API keys found\""
  },
  "keywords": [
    "okx",
    "trading",
    "strategy",
    "analysis",
    "crypto",
    "cli",
    "rsi",
    "macd",
    "technical-analysis",
    "signal",
    "risk-management"
  ],
  "author": "菊中菊 <yu230650@github.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "technicalindicators": "^3.1.0",
    "dotenv": "^16.3.0",
    "winston": "^3.11.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "standard": "^17.1.0",
    "prettier": "^3.1.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lobster-Tempo/trading-strategy-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Lobster-Tempo/trading-strategy-skill/issues"
  },
  "homepage": "https://github.com/Lobster-Tempo/trading-strategy-skill#readme",
  "files": [
    "src/",
    "scripts/",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "okxSkill": {
    "name": "smart-trading-signals",
    "title": "智能交易信号",
    "description": "调用OKX CLI命令的多策略交易信号分析",
    "version": "1.0.0",
    "category": "trading-analysis",
    "tags": ["trading", "strategy", "analysis", "crypto", "okx-cli"],
    "requires": ["okx-cli"],
    "commands": ["analyze", "batch", "history", "backtest"],
    "integration": {
      "dataSource": "okx-cli",
      "commandsUsed": ["market ticker", "market candles", "market indicator"],
      "strategy": "RSI + MACD双指标交叉验证"
    }
  }
}